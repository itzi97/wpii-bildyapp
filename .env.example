# Node.js environment
NODE_ENV=development

# Server
PORT=3000

# MongoDB Atlas (username and password placeholders)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/bildyapp?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_random_secret_of_at_least_32_characters
JWT_REFRESH_SECRET=replace_with_a_different_random_secret_of_at_least_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# File uploads (Multer)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Security (express rate limit)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass
MAIL_FROM=noreply@bildyapp.com

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
